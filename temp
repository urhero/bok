{
    "mcpServers": {
        "context7": {
            "command": "npx",
            "args": [
                "-y",
                "@upstash/context7-mcp",
                "--api-key",
                "발급받은 API 키 입력"
            ]
        },
        "sequential-thinking": {
            "command": "npx",
            "args": [
                "-y",
                "@modelcontextprotocol/server-sequential-thinking"
            ]
        },
        "TestSprite": {
            "command": "npx",
            "args": [
                "@testsprite/testsprite-mcp@latest"
            ],
            "env": {
                "API_KEY": "발급받은 API 키 입력",
                "PATH": "위 PATH 코드 경로 입력"
            }
        }
    }
}


